# Garmin Connect
GARMIN_EMAIL=your_email@example.com
# GARMIN_PASSWORD は macOS Keychain での管理を推奨（下記コマンドで登録）:
#   security add-generic-password -a "garmin" -s "auto-diary" -w "your_password"
# Keychain を使わない場合は以下のコメントを外して直接記入:
# GARMIN_PASSWORD=your_password

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Notion (MVP後に使用)
# NOTION_API_KEY=secret_xxxxx
# NOTION_DATABASE_ID=xxxxx

# アプリ設定
DIARY_TARGET_DATE=yesterday   # "yesterday" | "today" | "YYYY-MM-DD"
DIARY_LANGUAGE=ja
